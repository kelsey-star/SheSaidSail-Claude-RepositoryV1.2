{
  "name": "SSS-BRAND-ROUTER",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": "SSS_BRAND_ROUTER_HOOK",
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "restore": { "parameters": { "hook": { "label": "SSS Brand Router Webhook" } } }
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicRouter",
      "version": 1,
      "parameters": {},
      "mapper": {},
      "metadata": { "designer": { "x": 200, "y": 0 } },
      "routes": [
        {
          "filter": {
            "name": "SSS Route — shesaidsail.com",
            "conditions": [[
              { "a": "{{1.source_url}}", "o": "text:contain", "b": "shesaidsail.com" }
            ]]
          },
          "flow": [
            {
              "id": 5,
              "module": "airtable:ActionUpdateRecord",
              "version": 3,
              "parameters": {
                "base": "appdZ49WqgjRXxA1R",
                "table": "tblTlSB9CO4dTGodg"
              },
              "mapper": {
                "recordId": "{{1.request_record_id}}",
                "fields": {
                  "Brand": "SSS",
                  "Source_System": "Make"
                }
              },
              "metadata": {
                "designer": { "x": 450, "y": -200 },
                "restore": {
                  "parameters": {
                    "base": { "label": "She Said Sail" },
                    "table": { "label": "Requests" }
                  }
                }
              }
            }
          ]
        },
        {
          "filter": {
            "name": "ME Route — mareexecutive.com",
            "conditions": [[
              { "a": "{{1.source_url}}", "o": "text:contain", "b": "mareexecutive.com" }
            ]]
          },
          "flow": [
            {
              "id": 8,
              "module": "airtable:ActionUpdateRecord",
              "version": 3,
              "parameters": {
                "base": "appdZ49WqgjRXxA1R",
                "table": "tblTlSB9CO4dTGodg"
              },
              "mapper": {
                "recordId": "{{1.request_record_id}}",
                "fields": {
                  "Brand": "ME",
                  "Source_System": "Make"
                }
              },
              "metadata": {
                "designer": { "x": 450, "y": 0 },
                "restore": {
                  "parameters": {
                    "base": { "label": "She Said Sail" },
                    "table": { "label": "Requests" }
                  }
                }
              }
            }
          ]
        },
        {
          "filter": {
            "name": "UNKNOWN — neither SSS nor ME",
            "conditions": [[
              { "a": "{{1.source_url}}", "o": "text:notContain", "b": "shesaidsail.com" },
              { "a": "{{1.source_url}}", "o": "text:notContain", "b": "mareexecutive.com" }
            ]]
          },
          "flow": [
            {
              "id": 11,
              "module": "slack:ActionPostMessage",
              "version": 1,
              "parameters": {
                "channel": "#sss-ops-alerts"
              },
              "mapper": {
                "text": "⚠️ *Brand Classification UNKNOWN — Manual Action Required*\nInbound request from *{{1.source_url}}* could not be classified as SSS or ME.\n*Request ID:* {{1.request_record_id}}\nLuciana: please set the Brand field manually in Airtable.\n_{{formatDate(now; \"YYYY-MM-DD HH:mm\")}} UTC_"
              },
              "metadata": {
                "designer": { "x": 450, "y": 200 },
                "restore": {
                  "parameters": {
                    "channel": { "label": "#sss-ops-alerts" }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "us2.make.com",
    "notes": "AFTER IMPORT — 3 things to do: (1) REBIND Airtable connection on modules 5 and 8 — select SSS PAT, confirm base=appdZ49WqgjRXxA1R table=tblTlSB9CO4dTGodg (Requests). (2) REBIND Slack OAuth on module 11 — select SheSaidSail workspace, channel=#sss-ops-alerts. (3) COPY this scenario webhook URL and paste into M-LEAD-INTAKE module 5 field 'URL' replacing PASTE_BRAND_ROUTER_WEBHOOK_URL_HERE. Route filters are on route objects (not modules). Three routes: shesaidsail.com=SSS, mareexecutive.com=ME, neither=UNKNOWN+Slack alert."
  }
}
