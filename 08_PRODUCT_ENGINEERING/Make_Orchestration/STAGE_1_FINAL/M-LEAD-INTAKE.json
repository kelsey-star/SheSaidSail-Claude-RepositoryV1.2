{
  "name": "SSS-LEAD-INTAKE",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": "SSS_LEAD_INTAKE_HOOK",
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "restore": { "parameters": { "hook": { "label": "SSS Lead Intake Webhook — register in Webflow" } } }
      }
    },
    {
      "id": 3,
      "module": "airtable:SearchRecords",
      "version": 3,
      "parameters": {
        "base": "appdZ49WqgjRXxA1R",
        "table": "tblTlSB9CO4dTGodg"
      },
      "mapper": {
        "filterByFormula": "FIND(\"{{concat(\"LEAD-\"; sha256(join([1.email; 1.preferred_date; 1.guest_count]; \"|\")))}}\", {Idempotency_Key})"
      },
      "metadata": {
        "designer": { "x": 200, "y": 0 },
        "restore": {
          "parameters": {
            "base": { "label": "She Said Sail" },
            "table": { "label": "Requests" }
          }
        }
      }
    },
    {
      "id": 5,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": false, "useNewZLibDeCompress": true },
      "filter": {
        "name": "Skip if duplicate",
        "conditions": [[
          { "a": "{{3.id}}", "o": "text:notExist" }
        ]]
      },
      "mapper": {
        "url": "PASTE_BRAND_ROUTER_WEBHOOK_URL_HERE",
        "method": "POST",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": "{\"request_record_id\": \"\", \"source_url\": \"{{1.source_url}}\", \"form_name\": \"{{1.form_name}}\"}"
      },
      "metadata": { "designer": { "x": 400, "y": 0 } }
    },
    {
      "id": 6,
      "module": "json:ParseJSON",
      "version": 1,
      "parameters": {},
      "mapper": {
        "string": "{{5.body}}"
      },
      "metadata": { "designer": { "x": 600, "y": 0 } }
    },
    {
      "id": 7,
      "module": "airtable:ActionCreateRecord",
      "version": 3,
      "parameters": {
        "base": "appdZ49WqgjRXxA1R",
        "table": "tblTlSB9CO4dTGodg"
      },
      "mapper": {
        "fields": {
          "First Name": "{{1.first_name}}",
          "Last Name": "{{1.last_name}}",
          "Email": "{{1.email}}",
          "Phone": "{{1.phone}}",
          "Yacht": "{{1.yacht}}",
          "Experience": "{{1.experience}}",
          "Duration": "{{1.duration}}",
          "Preferred Date": "{{1.preferred_date}}",
          "Guest Count": "{{toNumber(1.guest_count)}}",
          "Add-Ons Selected": "{{1.add_ons}}",
          "Special Requests": "{{1.special_requests}}",
          "Status": "NEW",
          "Environment": "Production",
          "Source_System": "Make",
          "Brand": "{{6.brand}}",
          "Notes": "Source: {{1.source_url}} | Idempotency: {{concat(\"LEAD-\"; sha256(join([1.email; 1.preferred_date; 1.guest_count]; \"|\")))}}",
          "Idempotency_Key": "{{concat(\"LEAD-\"; sha256(join([1.email; 1.preferred_date; 1.guest_count]; \"|\")))}}"
        }
      },
      "metadata": {
        "designer": { "x": 800, "y": 0 },
        "restore": {
          "parameters": {
            "base": { "label": "She Said Sail" },
            "table": { "label": "Requests" }
          }
        }
      }
    },
    {
      "id": 8,
      "module": "gmail:ActionSendEmail",
      "version": 1,
      "parameters": {
        "account": "hello@shesaidsail.com"
      },
      "mapper": {
        "to": "{{1.email}}",
        "subject": "We received your {{if(6.brand = \"ME\"; \"Mare Executive\"; \"She Said Sail\")}} inquiry, {{1.first_name}}!",
        "bodyType": "html",
        "body": "<p>Hi {{1.first_name}},</p><p>Thank you for reaching out! We've received your inquiry and our team will be in touch within a few hours to discuss availability and details for your {{1.occasion}} experience.</p><p>Here's a summary of what you submitted:</p><ul><li><strong>Experience:</strong> {{1.experience}}</li><li><strong>Preferred Date:</strong> {{1.preferred_date}}</li><li><strong>Guests:</strong> {{1.guest_count}}</li></ul><p>We'll reach out shortly. In the meantime, feel free to reply to this email with any questions.</p><p>Warmly,<br>The {{if(6.brand = \"ME\"; \"Mare Executive\"; \"She Said Sail\")}} Team</p>"
      },
      "metadata": {
        "designer": { "x": 1000, "y": 0 },
        "restore": {
          "parameters": {
            "account": { "label": "hello@shesaidsail.com" }
          }
        }
      }
    },
    {
      "id": 9,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": false, "useNewZLibDeCompress": true },
      "mapper": {
        "url": "PASTE_SLACK_ALERTS_WEBHOOK_URL_HERE",
        "method": "POST",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": "{\"alert_type\": \"LEAD\", \"severity\": \"INFO\", \"title\": \"New {{6.brand}} Lead\", \"body\": \"{{1.first_name}} {{1.last_name}} — {{1.occasion}} — {{1.preferred_date}} — {{1.guest_count}} guests\", \"booking_id\": \"{{7.id}}\", \"city\": \"{{1.city}}\", \"brand\": \"{{6.brand}}\", \"lead_name\": \"{{1.first_name}} {{1.last_name}}\", \"occasion\": \"{{1.occasion}}\", \"preferred_date\": \"{{1.preferred_date}}\", \"guest_count\": \"{{1.guest_count}}\", \"source\": \"{{1.source_url}}\"}"
      },
      "metadata": { "designer": { "x": 1200, "y": 0 } }
    },
    {
      "id": 10,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": false, "useNewZLibDeCompress": true },
      "mapper": {
        "url": "PASTE_AUDIT_LOGGER_WEBHOOK_URL_HERE",
        "method": "POST",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": "{\"triggering_event\": \"Webflow form submission — Lead Intake\", \"source_data\": \"Email: {{1.email}}, Date: {{1.preferred_date}}, Guests: {{1.guest_count}}, Source: {{1.source_url}}\", \"output\": \"Request record created: {{7.id}}. Auto-reply sent. Slack notified.\", \"approval_state\": \"AUTONOMOUS\", \"brand\": \"{{6.brand}}\", \"city\": \"{{1.city}}\", \"environment\": \"Production\", \"model_version\": \"N/A\", \"destination\": \"Airtable Requests + Gmail + Slack #sss-lead-intake\"}"
      },
      "metadata": { "designer": { "x": 1400, "y": 0 } }
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": true,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    },
    "zone": "us2.make.com",
    "notes": "REBINDING REQUIRED: Airtable connection (modules 3, 7), Gmail connection (module 8). PLACEHOLDERS: replace PASTE_BRAND_ROUTER_WEBHOOK_URL_HERE (module 5), PASTE_SLACK_ALERTS_WEBHOOK_URL_HERE (module 9), PASTE_AUDIT_LOGGER_WEBHOOK_URL_HERE (module 10). Register webhook URL in Webflow → Form Submission. Idempotency: checks Requests table for matching idempotency key before creating new record. All variables from builtin:SetVariables have been inlined."
  }
}
